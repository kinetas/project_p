 title\n    TEXT content\n    DATETIME created_at\n    DATETIME updated_at\n  }\n\n  COMMENT {\n    BIGINT id PK\n    BIGINT journal_id FK\n    BIGINT user_id FK\n    TEXT content\n    DATETIME created_at\n    DATETIME updated_at\n  }\n\n  COMPANY ||--o{ FINANCIAL_STATEMENT : \&quot;stock_code\&quot;\n  COMPANY ||--|| STOCK_PRICE : \&quot;stock_code=srtn_cd\&quot;\n  COMPANY ||--|| DIVIDEND_INFO : \&quot;corp_code\&quot;\n  COMPANY ||--|| STOCK_INDICATOR : \&quot;stock_code\&quot;\n  COMPANY ||--|| TOP100 : \&quot;stock_code\&quot;\n  COMPANY ||--o{ USER_FAVORITE : \&quot;stock_code\&quot;\n\n  USER ||--o{ USER_FAVORITE : \&quot;user_id\&quot;\n  USER ||--o{ INVESTMENT_JOURNAL : \&quot;user_id\&quot;\n  USER ||--o{ COMMENT : \&quot;user_id\&quot;\n  INVESTMENT_JOURNAL ||--o{ COMMENT : \&quot;journal_id\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="352">
